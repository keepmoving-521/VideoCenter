VIDEOCENTER_ENVIRONMENT=development
VIDEOCENTER_APP_NAME=VideoCenter Development
VIDEOCENTER_DEBUG=true
VIDEOCENTER_LOG_LEVEL=DEBUG
VIDEOCENTER_LOG_FORMAT=text
VIDEOCENTER_LOG_FILE_ENABLED=true
VIDEOCENTER_LOG_DIR=./data/logs
VIDEOCENTER_LOG_FILE_NAME=videocenter-development.log
VIDEOCENTER_LOG_MAX_BYTES=10485760
VIDEOCENTER_LOG_BACKUP_COUNT=5
VIDEOCENTER_DOCS_ENABLED=true
VIDEOCENTER_DATABASE_ECHO=false
VIDEOCENTER_DATABASE_URL=sqlite:///./data/videocenter-development.db
VIDEOCENTER_MEDIA_ROOT=./data/media
VIDEOCENTER_FFMPEG_PATH=
VIDEOCENTER_FFPROBE_PATH=
VIDEOCENTER_API_PREFIX=/api/v1
VIDEOCENTER_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
