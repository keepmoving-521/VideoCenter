VIDEOCENTER_ENVIRONMENT=production
VIDEOCENTER_APP_NAME=VideoCenter
VIDEOCENTER_DEBUG=false
VIDEOCENTER_LOG_LEVEL=INFO
VIDEOCENTER_LOG_FORMAT=json
VIDEOCENTER_LOG_FILE_ENABLED=true
VIDEOCENTER_LOG_DIR=./data/logs
VIDEOCENTER_LOG_FILE_NAME=videocenter.log
VIDEOCENTER_LOG_MAX_BYTES=10485760
VIDEOCENTER_LOG_BACKUP_COUNT=10
VIDEOCENTER_DOCS_ENABLED=false
VIDEOCENTER_DATABASE_ECHO=false
VIDEOCENTER_DATABASE_URL=sqlite:///./data/videocenter.db
VIDEOCENTER_MEDIA_ROOT=./data/media
VIDEOCENTER_FFMPEG_PATH=
VIDEOCENTER_FFPROBE_PATH=
VIDEOCENTER_HLS_WORKER_COUNT=1
VIDEOCENTER_HLS_CACHE_RETENTION_HOURS=168
VIDEOCENTER_API_PREFIX=/api/v1
VIDEOCENTER_CORS_ORIGINS=[]
